@using System.ComponentModel.DataAnnotations
@using jsnover.net.blazor.Models

<EditForm Model="PhotoData" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="form-group mb-3">
        <label class="form-label" for="photoTitle">Title <span class="text-danger">*</span></label>
        <InputText id="photoTitle" class="form-control shadow-border-sm" @bind-Value="PhotoData.Title" placeholder="Enter photo title" />
        <ValidationMessage For="@(() => PhotoData.Title)" />
        <small class="text-muted d-block mt-1">Required, max 250 characters</small>
    </div>

    <div class="form-group mb-3">
        <label class="form-label" for="photoDescription">Description</label>
        <InputTextArea id="photoDescription" class="form-control shadow-border-sm" @bind-Value="PhotoData.Description" placeholder="Enter photo description" rows="3" />
        <ValidationMessage For="@(() => PhotoData.Description)" />
        <small class="text-muted d-block mt-1">Max 1000 characters</small>
    </div>

    <div class="form-group mb-3">
        <label class="form-label" for="photoUrl">Photo URL <span class="text-danger">*</span></label>
        <InputText id="photoUrl" type="url" class="form-control shadow-border-sm" @bind-Value="PhotoData.Url" placeholder="https://example.com/photo.jpg" />
        <ValidationMessage For="@(() => PhotoData.Url)" />
        <small class="text-muted d-block mt-1">Required, max 500 characters</small>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="form-group mb-3">
                <label class="form-label" for="photoOrder">Display Order</label>
                <InputNumber id="photoOrder" class="form-control shadow-border-sm" @bind-Value="PhotoData.DisplayOrder" />
                <ValidationMessage For="@(() => PhotoData.DisplayOrder)" />
                <small class="text-muted d-block mt-1">Lower numbers appear first</small>
            </div>
        </div>

        <div class="col-md-6">
            <div class="form-group mb-3">
                <div class="form-check mt-4">
                    <InputCheckbox id="isPublished" class="form-check-input" @bind-Value="PhotoData.IsPublished" />
                    <label class="form-check-label" for="isPublished">
                        Publish this photo
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="form-group mt-4">
        <button type="submit" class="btn btn-primary shadow-border-sm" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Saving...</span>
            }
            else
            {
                <span>Save Photo</span>
            }
        </button>
    </div>
</EditForm>

@code {
    [Parameter]
    public StandalonePhoto EditContext { get; set; } = new StandalonePhoto();

    [Parameter]
    public EventCallback<StandalonePhoto> OnSubmit { get; set; }

    private StandalonePhoto PhotoData { get; set; } = new StandalonePhoto();
    private bool isSubmitting = false;

    protected override void OnParametersSet()
    {
        if (EditContext != null)
        {
            PhotoData = new StandalonePhoto
            {
                PhotoId = EditContext.PhotoId,
                Title = EditContext.Title ?? string.Empty,
                Description = EditContext.Description ?? string.Empty,
                Url = EditContext.Url ?? string.Empty,
                DisplayOrder = EditContext.DisplayOrder,
                IsPublished = EditContext.IsPublished
            };
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            isSubmitting = true;
            
            // Validate required fields
            if (string.IsNullOrWhiteSpace(PhotoData.Title) || PhotoData.Title.Length > 250)
            {
                throw new ValidationException("Title is required and must be 250 characters or less");
            }

            if (string.IsNullOrWhiteSpace(PhotoData.Url) || PhotoData.Url.Length > 500)
            {
                throw new ValidationException("URL is required and must be 500 characters or less");
            }

            if (PhotoData.Description?.Length > 1000)
            {
                throw new ValidationException("Description must be 1000 characters or less");
            }

            // Update UploadDate if new record
            if (PhotoData.PhotoId == 0)
            {
                PhotoData.UploadDate = DateTime.Now;
                PhotoData.CreatedDate = DateTime.Now;
            }

            await OnSubmit.InvokeAsync(PhotoData);
            
            // Reset form
            PhotoData = new StandalonePhoto();
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
