@page "/admin/photos"
@using System.ComponentModel.DataAnnotations
@using jsnover.net.blazor.Models
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager nav
@inject ILogger<PhotoManagement> logger

<div class="photo-management pad-25x3">
    <div class="col-lg-12 jsno-background rounded-lg shadow-border">
        <h2>Photo Management</h2>

        <!-- Upload/Add Photo Form Section -->
        <div class="form-section my-4">
            <h4 class="mb-3">
                @if (isEditMode && selectedPhoto != null)
                {
                    <span>Edit Photo</span>
                }
                else
                {
                    <span>Add New Photo</span>
                }
            </h4>

            <AdminPhotoForm EditContext="photoFormModel" OnSubmit="HandlePhotoSubmit" />

            @if (isEditMode)
            {
                <button class="btn btn-secondary mt-2" @onclick="CancelEdit">Cancel Edit</button>
            }
        </div>

        <hr class="my-4" />

        <!-- Photos List Section -->
        <div class="list-section">
            <h4 class="mb-3">All Photos (@allPhotos.Count)</h4>

            @if (isLoading)
            {
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p>Loading photos...</p>
                </div>
            }
            else if (allPhotos.Count == 0)
            {
                <p class="text-muted">No photos found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>URL</th>
                                <th>Order</th>
                                <th>Published</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var photo in allPhotos)
                            {
                                <tr>
                                    <td>
                                        <strong>@photo.Title</strong>
                                        <br />
                                        <small class="text-muted">@photo.Description?.Substring(0, Math.Min(50, photo.Description?.Length ?? 0))...</small>
                                    </td>
                                    <td>
                                        <a href="@photo.Url" target="_blank" class="text-truncate d-inline-block" style="max-width: 200px;">
                                            @photo.Url
                                        </a>
                                    </td>
                                    <td>@photo.DisplayOrder</td>
                                    <td>
                                        <span class="badge @(photo.IsPublished ? "bg-success" : "bg-secondary")">
                                            @(photo.IsPublished ? "Published" : "Draft")
                                        </span>
                                    </td>
                                    <td>@photo.CreatedDate.ToShortDateString()</td>
                                    <td>
                                        <button class="btn btn-sm btn-info" @onclick="@(() => EditPhoto(photo))" title="Edit">Edit</button>
                                        <button class="btn btn-sm btn-danger" @onclick="@(() => DeletePhoto(photo))" title="Delete">Delete</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Success/Error Messages -->
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                <strong>Success!</strong> @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <strong>Error!</strong> @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
            </div>
        }

        <!-- Delete Confirmation Modal -->
        @if (showDeleteConfirm && deleteConfirmPhoto != null)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show d-block" tabindex="-1" style="display: block; background-color: rgba(0,0,0,.5);">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Confirm Delete</h5>
                            <button type="button" class="btn-close" @onclick="() => showDeleteConfirm = false"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete this photo?</p>
                            <p><strong>@deleteConfirmPhoto.Title</strong></p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="() => showDeleteConfirm = false">Cancel</button>
                            <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private List<StandalonePhoto> allPhotos = new();
    private StandalonePhoto photoFormModel = new();
    private StandalonePhoto selectedPhoto;
    private bool isEditMode = false;
    private bool isLoading = true;
    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;
    private bool showDeleteConfirm = false;
    private StandalonePhoto deleteConfirmPhoto;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initialize photo list from service
            isLoading = true;
            // TODO: Inject PhotoGalleryService and load photos
            // allPhotos = await photoGalleryService.GetAllPhotosAsync();
            allPhotos = new List<StandalonePhoto>
            {
                // Placeholder for demonstration
            };
            isLoading = false;
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to load photos";
            logger.LogError(ex, "Error loading photos");
            isLoading = false;
        }
    }

    private async Task HandlePhotoSubmit(StandalonePhoto photo)
    {
        try
        {
            if (isEditMode)
            {
                // TODO: Update photo via PhotoGalleryService
                // await photoGalleryService.UpdatePhotoAsync(photo);
                successMessage = "Photo updated successfully!";
                isEditMode = false;
            }
            else
            {
                // TODO: Add new photo via PhotoGalleryService
                // await photoGalleryService.AddPhotoAsync(photo);
                successMessage = "Photo added successfully!";
            }

            // Reload photos
            OnInitializedAsync().Wait();
            photoFormModel = new StandalonePhoto();
            selectedPhoto = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error saving photo: {ex.Message}";
            logger.LogError(ex, "Error saving photo");
        }
    }

    private void EditPhoto(StandalonePhoto photo)
    {
        selectedPhoto = photo;
        photoFormModel = new StandalonePhoto
        {
            PhotoId = photo.PhotoId,
            Title = photo.Title,
            Description = photo.Description,
            Url = photo.Url,
            DisplayOrder = photo.DisplayOrder,
            IsPublished = photo.IsPublished
        };
        isEditMode = true;
        successMessage = string.Empty;
        errorMessage = string.Empty;
    }

    private void CancelEdit()
    {
        isEditMode = false;
        selectedPhoto = null;
        photoFormModel = new StandalonePhoto();
    }

    private void DeletePhoto(StandalonePhoto photo)
    {
        deleteConfirmPhoto = photo;
        showDeleteConfirm = true;
    }

    private async Task ConfirmDelete()
    {
        try
        {
            // TODO: Delete photo via PhotoGalleryService
            // await photoGalleryService.DeletePhotoAsync(deleteConfirmPhoto.PhotoId);
            
            allPhotos.Remove(deleteConfirmPhoto);
            showDeleteConfirm = false;
            successMessage = "Photo deleted successfully!";
            deleteConfirmPhoto = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting photo: {ex.Message}";
            logger.LogError(ex, "Error deleting photo");
            showDeleteConfirm = false;
        }
    }
}
